# Airtable
AIRTABLE_PAT=pat_xxx
AIRTABLE_BASE_ID=app_xxx
AIRTABLE_INVITEES_TABLE=Invitees
AIRTABLE_RSVPS_TABLE=RSVPs
# Optional: a one-row Settings table with an "RSVP deadline" Date field.
# When set and the deadline has passed, the form is replaced with a "closed" message.
AIRTABLE_SETTINGS_TABLE=Settings
# Notes table for the public notes wall feature. See docs/host-guide.md for schema.
AIRTABLE_NOTES_TABLE=Notes

# Resend
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=rsvp@your-domain.example
RESEND_TO_EMAIL=you@your-domain.example

# Seed script
SITE_BASE_URL=https://your-domain.example
